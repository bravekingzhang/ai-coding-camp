# ── 数据库 / 队列 ──────────────────────────────────
DATABASE_URL="postgresql://camp:camp@localhost:5432/camp"
REDIS_URL="redis://localhost:6379"

# ── 会话与安全 ────────────────────────────────────
SESSION_SECRET="change-me-32-bytes-random-string!!"
CI_SHARED_TOKEN="change-me-ci-token"          # CI 回调用（.gitlab-ci.yml 中的 CAMP_CI_TOKEN）
GIT_WEBHOOK_SECRET="change-me-webhook-secret" # Git 平台 webhook 的 Secret Token

# ── 课程内容（landing-zone-camp 的绝对路径）────────
CAMP_CONTENT_DIR="/opt/ai-coding-camp/landing-zone-camp"

# ── 外设适配器 ────────────────────────────────────
LLM_MODE="mock"                # mock | gateway
LLM_GATEWAY_URL=""             # gateway 模式下的内部网关地址
IM_WEBHOOK_URL=""              # 企业微信/钉钉/飞书 群机器人 webhook，留空则打印到日志
SKILLHUB_API_URL=""            # SkillHub API，留空则跳过轮询

# ── 系统设置（也可在 管理→系统设置 页配置，DB 优先于环境变量）─────
trainingRepoUrl=""             # 训练仓库 clone 地址（新手引导页用），如 ssh://git@.../camp.git
trainingRepoWebUrl=""          # 训练仓库网页浏览地址（用于生成评审/教练查看产物的链接）
repoBranchUrlTemplate=""       # 分支浏览链接模板，默认 {web}/-/tree/{branch}/{path}（GitLab 格式）
